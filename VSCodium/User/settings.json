{
    "workbench.colorTheme": "Gruvbox Dark Hard",
    "editor.cursorSmoothCaretAnimation": "on",
    "editor.smoothScrolling": true,
    "workbench.list.smoothScrolling": true,
    "terminal.integrated.smoothScrolling": true,
    "terminal.integrated.fontFamily": "JetBrainsMono Nerd Font",
    "terminal.integrated.fontSize": 12,
    "terminal.integrated.fontLigatures": true,
    "terminal.integrated.cursorStyle": "line",
    "terminal.integrated.cursorStyleInactive": "line",
    "terminal.integrated.cursorBlinking": true,
    "terminal.integrated.cursorWidth": 2,
    "terminal.integrated.scrollback": 10000,
    "terminal.integrated.gpuAcceleration": "on",
    "workbench.colorCustomizations": {
        "terminal.foreground": "#e8e8e8",
        "terminal.background": "#181818",
        "terminal.ansiBlack": "#212121",
        "terminal.ansiBrightBlack": "#686868",
        "terminal.ansiRed": "#7d4d4d",
        "terminal.ansiBrightRed": "#b08080",
        "terminal.ansiGreen": "#4d7d4d",
        "terminal.ansiBrightGreen": "#80b080",
        "terminal.ansiYellow": "#7d7d4d",
        "terminal.ansiBrightYellow": "#b0b080",
        "terminal.ansiBlue": "#4d6580",
        "terminal.ansiBrightBlue": "#80a0b8",
        "terminal.ansiMagenta": "#4d6d80",
        "terminal.ansiBrightMagenta": "#80a8b8",
        "terminal.ansiCyan": "#4d807d",
        "terminal.ansiBrightCyan": "#80b8a8",
        "terminal.ansiWhite": "#808080",
        "terminal.ansiBrightWhite": "#e8e8e8",
        "terminal.selectionBackground": "#e8e8e8",
        "terminal.selectionForeground": "#181818",
        "terminalCursor.foreground": "#e8e8e8"
    },
    "accessibility.signals.terminalBell": {
        "sound": "off"
    },
    "terminal.integrated.enableVisualBell": false
}
