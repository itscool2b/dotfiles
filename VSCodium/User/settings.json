{
    "workbench.colorTheme": "Gruvbox Dark Hard",
    "editor.cursorSmoothCaretAnimation": "on",
    "editor.smoothScrolling": true,
    "workbench.list.smoothScrolling": true,
    "terminal.integrated.smoothScrolling": true,
    "terminal.integrated.fontFamily": "JetBrainsMono Nerd Font",
    "terminal.integrated.fontSize": 12,
    "terminal.integrated.fontLigatures": true,
    "terminal.integrated.cursorStyle": "line",
    "terminal.integrated.cursorStyleInactive": "line",
    "terminal.integrated.cursorBlinking": true,
    "terminal.integrated.cursorWidth": 2,
    "terminal.integrated.scrollback": 10000,
    "terminal.integrated.gpuAcceleration": "on",
    "workbench.colorCustomizations": {
        "terminal.foreground": "#d4be98",
        "terminal.background": "#1d2021",
        "terminal.ansiBlack": "#282828",
        "terminal.ansiBrightBlack": "#7c6f64",
        "terminal.ansiRed": "#ea6962",
        "terminal.ansiBrightRed": "#f2594b",
        "terminal.ansiGreen": "#a9b665",
        "terminal.ansiBrightGreen": "#b0b846",
        "terminal.ansiYellow": "#d8a657",
        "terminal.ansiBrightYellow": "#e5b975",
        "terminal.ansiBlue": "#7daea3",
        "terminal.ansiBrightBlue": "#8fbcbb",
        "terminal.ansiMagenta": "#d3869b",
        "terminal.ansiBrightMagenta": "#e0a0b5",
        "terminal.ansiCyan": "#89b482",
        "terminal.ansiBrightCyan": "#9ac197",
        "terminal.ansiWhite": "#928374",
        "terminal.ansiBrightWhite": "#d4be98",
        "terminal.selectionBackground": "#d4be98",
        "terminal.selectionForeground": "#1d2021",
        "terminalCursor.foreground": "#d4be98"
    },
    "accessibility.signals.terminalBell": {
        "sound": "off"
    },
    "terminal.integrated.enableVisualBell": false
}
