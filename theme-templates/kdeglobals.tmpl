#  kdeglobals — generated from theme.toml
#  Unifies icon + cursor between GTK and KDE apps (Dolphin, etc.)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

[General]
ColorScheme={{ accents.kde.color_scheme }}
Name=Current

[Icons]
Theme={{ accents.kde.icons }}

[KDE]
AnimationDurationFactor=0.25
widgetStyle=Breeze

[Mouse]
cursorTheme={{ accents.kde.cursor }}
cursorSize={{ cursor.size }}
