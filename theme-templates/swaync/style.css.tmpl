/* ━━━ {{ meta.name }} — swaync: premium floating notifications ━━━ */
/* Generated from theme.toml — do not edit directly */

@define-color bg0      {{ colors.bg0 }};
@define-color bg1      {{ colors.bg1 }};
@define-color bg2      {{ colors.bg2 }};
@define-color bg3      {{ colors.bg3 }};
@define-color bg4      {{ colors.bg4 }};
@define-color fg       {{ colors.fg }};
@define-color fg_dim   {{ colors.fg_dim }};
@define-color fg_light {{ colors.fg_light }};
@define-color yellow   {{ colors.bright_yellow }};
@define-color orange   {{ colors.bright_orange }};
@define-color red      {{ colors.bright_red }};

@define-color sn_title    {{ accents.swaync.title }};
@define-color sn_summary  {{ accents.swaync.summary }};
@define-color sn_dnd      {{ accents.swaync.dnd_switch }};
@define-color sn_action   {{ accents.swaync.action }};
@define-color sn_ambient  {{ accents.swaync.close_ambient }};
@define-color sn_close    {{ accents.swaync.close_hover }};
@define-color sn_time     {{ accents.swaync.timestamp }};

* {
    font-family: "{{ fonts.mono_display }}", "{{ fonts.mono }}", sans-serif;
    font-size: {{ fonts.size.notification }}px;
}

/* ━━━ Control center — warm glass panel with depth ━━━ */
.control-center {
    background: alpha(@bg0, {{ opacity.swaync_cc }});
    border: 1px solid alpha(@fg_light, 0.18);
    border-radius: {{ geometry.swaync_cc_radius }}px;
    padding: 14px;
    box-shadow: 0 18px 48px alpha(@bg0, 0.50), inset 0 1px alpha(@fg_light, 0.08);
}

@keyframes notif-enter {
    from { opacity: 0; margin-top: -8px; }
    to   { opacity: 1; margin-top: 0; }
}

.notification-row {
    outline: none;
    margin: 6px 0;
    animation: notif-enter {{ motion.lifecycle_ms }}ms {{ motion.focus_curve }};
}

.notification {
    background: alpha(@bg1, {{ opacity.swaync_notif }});
    border: 1px solid alpha(@fg_light, 0.14);
    border-radius: {{ geometry.swaync_notif_radius }}px;
    padding: 10px;
    margin: 4px;
    box-shadow: 0 10px 30px alpha(@bg0, 0.38), inset 0 1px alpha(@fg_light, 0.07);
    transition: background {{ motion.hover_ms }}ms {{ motion.hover_curve }},
                border-color {{ motion.hover_ms }}ms {{ motion.hover_curve }},
                box-shadow {{ motion.hover_ms }}ms {{ motion.hover_curve }};
}

.notification:hover {
    background: alpha(@bg2, 0.92);
    border-color: alpha(@yellow, 0.40);
    box-shadow: 0 14px 36px alpha(@bg0, 0.46), inset 0 1px alpha(@fg_light, 0.10);
}

.notification-content {
    padding: 8px 12px;
}

.summary {
    color: @sn_summary;
    font-weight: 800;
    font-size: 14px;
    letter-spacing: 0.02em;
}

.body {
    color: @fg_dim;
    font-size: 12px;
    margin-top: 4px;
    line-height: 1.35;
}

.time {
    color: @sn_time;
    font-size: 10px;
    letter-spacing: 0.10em;
    font-weight: 700;
}

.image,
.notification image {
    border-radius: 10px;
    margin-right: 10px;
}

.close-button {
    background: alpha(@bg2, 0.35);
    color: @sn_ambient;
    border-radius: 999px;
    padding: 3px 8px;
    border: 1px solid alpha(@fg_light, 0.08);
    box-shadow: inset 0 1px alpha(@fg_light, 0.05);
    transition: background {{ motion.hover_ms }}ms {{ motion.hover_curve }},
                color {{ motion.hover_ms }}ms {{ motion.hover_curve }},
                border-color {{ motion.hover_ms }}ms {{ motion.hover_curve }};
}

.close-button:hover {
    background: alpha(@bg4, 0.65);
    color: @sn_close;
    border-color: alpha(@fg_light, 0.18);
}

.notification-action,
.notification-default-action {
    border-radius: 10px;
}

.notification-action button {
    background: alpha(@bg2, 0.45);
    color: @sn_action;
    border: 1px solid alpha(@yellow, 0.16);
    border-radius: 10px;
    padding: 6px 10px;
}

.notification-action button:hover,
.notification-default-action:hover {
    background: alpha(@yellow, 0.12);
    border-color: alpha(@yellow, 0.34);
}

/* Semantic states: low recedes, critical gets a clear red rail. */
.notification.low {
    background: alpha(@bg0, 0.82);
    border-color: alpha(@fg_dim, 0.08);
    box-shadow: 0 8px 22px alpha(@bg0, 0.28), inset 0 1px alpha(@fg_light, 0.04);
}

.notification.critical {
    border-left: 4px solid @red;
    border-color: alpha(@red, 0.42);
    box-shadow: 0 12px 34px alpha(@bg0, 0.44), 0 0 0 1px alpha(@red, 0.12), inset 0 1px alpha(@fg_light, 0.08);
}

/* ━━━ Panel header ━━━ */
.widget-title {
    color: @sn_title;
    font-size: 15px;
    font-weight: 800;
    letter-spacing: 0.06em;
    padding: 10px 6px;
}

.widget-title button {
    background: alpha(@bg2, 0.42);
    color: @fg_dim;
    border-radius: 999px;
    padding: 5px 14px;
    border: 1px solid alpha(@fg_light, 0.12);
    box-shadow: inset 0 1px alpha(@fg_light, 0.06);
    transition: background {{ motion.hover_ms }}ms {{ motion.hover_curve }},
                color {{ motion.hover_ms }}ms {{ motion.hover_curve }},
                border-color {{ motion.hover_ms }}ms {{ motion.hover_curve }};
}

.widget-title button:hover {
    background: alpha(@yellow, 0.12);
    color: @fg_light;
    border-color: alpha(@yellow, 0.35);
}

/* ━━━ DND toggle ━━━ */
.widget-dnd {
    color: @fg_dim;
    padding: 8px 6px 12px;
    font-size: 12px;
    letter-spacing: 0.04em;
}

.widget-dnd > switch {
    background: alpha(@bg2, 0.75);
    border-radius: 999px;
    border: 1px solid alpha(@fg_light, 0.14);
    box-shadow: inset 0 1px alpha(@fg_light, 0.05);
    transition: background {{ motion.focus_ms }}ms {{ motion.focus_curve }},
                border-color {{ motion.focus_ms }}ms {{ motion.focus_curve }};
}

.widget-dnd > switch:checked {
    background: alpha(@sn_dnd, 0.88);
    border-color: @sn_dnd;
}

.widget-dnd > switch slider {
    background: @fg_light;
    border-radius: 50%;
    box-shadow: 0 2px 8px alpha(@bg0, 0.35);
}
