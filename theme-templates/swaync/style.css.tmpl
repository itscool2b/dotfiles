@define-color bg0     {{ colors.bg0 }};
@define-color bg1     {{ colors.bg1 }};
@define-color bg2     {{ colors.bg2 }};
@define-color bg3     {{ colors.bg3 }};
@define-color fg      {{ colors.fg }};
@define-color fg_dim  {{ colors.fg_dim }};
@define-color fg_light {{ colors.fg_light }};
@define-color red     {{ colors.bright_red }};
@define-color green   {{ colors.bright_green }};
@define-color yellow  {{ colors.bright_yellow }};
@define-color blue    {{ colors.bright_blue }};
@define-color purple  {{ colors.bright_purple }};
@define-color aqua    {{ colors.bright_cyan }};
@define-color orange  {{ colors.bright_orange }};

@define-color sn_title         {{ accents.swaync.title }};
@define-color sn_summary       {{ accents.swaync.summary }};
@define-color sn_dnd           {{ accents.swaync.dnd_switch }};
@define-color sn_close_ambient {{ accents.swaync.close_ambient }};
@define-color sn_close_hover   {{ accents.swaync.close_hover }};

* {
    font-family: "{{ fonts.mono }}", sans-serif;
    font-size: {{ fonts.size.notification }}px;
}

.control-center {
    background: alpha(@bg0, {{ opacity.swaync_cc }});
    border: 2px solid alpha(@bg3, 0.5);
    border-radius: {{ geometry.swaync_cc_radius }}px;
    padding: 12px;
}

@keyframes notif-enter {
    from { opacity: 0; margin-top: -6px; }
    to   { opacity: 1; margin-top: 4px; }
}

.notification-row {
    outline: none;
    margin: 4px 0;
    animation: notif-enter {{ motion.lifecycle_ms }}ms {{ motion.spring_curve }};
}

.notification {
    background: alpha(@bg1, {{ opacity.swaync_notif }});
    border: 1px solid alpha(@bg3, 0.4);
    border-radius: {{ geometry.swaync_notif_radius }}px;
    padding: 8px;
    margin: 4px;
    transition: background {{ motion.hover_ms }}ms {{ motion.hover_curve }},
                border-color {{ motion.hover_ms }}ms {{ motion.hover_curve }};
}

.notification:hover {
    background: alpha(@bg2, 0.92);
    border-color: alpha(@bg4, 0.7);
}

.notification-content {
    padding: 8px;
}

.summary {
    color: @sn_summary;
    font-weight: bold;
    font-size: 14px;
}

.body {
    color: @fg;
}

.time {
    color: @fg_dim;
    font-size: 11px;
}

.close-button {
    background: alpha(@sn_close_ambient, 0.18);
    color: @sn_close_ambient;
    border-radius: 8px;
    padding: 2px 8px;
    border: none;
    transition: background {{ motion.hover_ms }}ms {{ motion.hover_curve }},
                color {{ motion.hover_ms }}ms {{ motion.hover_curve }};
}

.close-button:hover {
    background: @sn_close_hover;
    color: @bg0;
}

.notification.critical {
    border-color: @red;
}

.notification.low {
    border-color: alpha(@bg3, 0.2);
}

.widget-title {
    color: @sn_title;
    font-size: 16px;
    font-weight: bold;
    padding: 8px;
}

.widget-title button {
    background: alpha(@sn_close_ambient, 0.15);
    color: @sn_close_ambient;
    border-radius: 10px;
    padding: 4px 16px;
    border: none;
    transition: background {{ motion.hover_ms }}ms {{ motion.hover_curve }},
                color {{ motion.hover_ms }}ms {{ motion.hover_curve }};
}

.widget-title button:hover {
    background: @sn_close_hover;
    color: @bg0;
}

.widget-dnd {
    color: @fg;
    padding: 8px;
}

.widget-dnd > switch {
    background: @bg2;
    border-radius: 10px;
    transition: background {{ motion.focus_ms }}ms {{ motion.focus_curve }};
}

.widget-dnd > switch:checked {
    background: @sn_dnd;
}

.widget-dnd > switch slider {
    background: @fg;
    border-radius: 50%;
}
