# Theme: {{ meta.name }} — generated by theme-generate.py

# Main background and foreground
theme[main_bg]="{{ colors.bg0 }}"
theme[main_fg]="{{ colors.fg }}"

# Title and highlight
theme[title_fg]="{{ colors.fg }}"
theme[hi_fg]="{{ accents.btop.highlight }}"

# Selection
theme[selected_bg]="{{ colors.bg2 }}"
theme[selected_fg]="{{ accents.btop.selected }}"

# Inactive
theme[inactive_fg]="{{ colors.fg_dim }}"

# Miscellaneous process info
theme[proc_misc]="{{ accents.btop.proc_misc }}"

# Box outlines
theme[cpu_box]="{{ accents.btop.cpu_box }}"
theme[mem_box]="{{ accents.btop.mem_box }}"
theme[net_box]="{{ accents.btop.net_box }}"
theme[proc_box]="{{ accents.btop.proc_box }}"

# CPU graph gradient
theme[cpu_start]="{{ colors.bright_cyan }}"
theme[cpu_mid]="{{ colors.bright_yellow }}"
theme[cpu_end]="{{ colors.bright_red }}"

# Temperature gradient
theme[temp_start]="{{ colors.bright_green }}"
theme[temp_mid]="{{ colors.bright_yellow }}"
theme[temp_end]="{{ colors.bright_red }}"

# Memory free gradient
theme[free_start]="{{ colors.bright_green }}"
theme[free_mid]="{{ colors.bright_yellow }}"
theme[free_end]="{{ colors.bright_red }}"

# Memory cached gradient
theme[cached_start]="{{ colors.bright_blue }}"
theme[cached_mid]="{{ colors.blue }}"
theme[cached_end]="{{ colors.bright_purple }}"

# Memory available gradient
theme[available_start]="{{ colors.bright_cyan }}"
theme[available_mid]="{{ colors.cyan }}"
theme[available_end]="{{ colors.bright_green }}"

# Memory used gradient
theme[used_start]="{{ colors.bright_yellow }}"
theme[used_mid]="{{ colors.bright_orange }}"
theme[used_end]="{{ colors.bright_red }}"

# Network
theme[download]="{{ accents.btop.download }}"
theme[upload]="{{ accents.btop.upload }}"
