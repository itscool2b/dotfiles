/* ━━━ {{ meta.name }} — SwayOSD theme ━━━ */
/* Generated from theme.toml — do not edit directly */

window#osd {
    background-color: transparent;
    color: {{ accents.swayosd.text }};
    border-radius: {{ swayosd.radius }}px;
}

@keyframes osd-enter {
    from { opacity: 0; margin-top: 24px; }
    to   { opacity: 1; margin-top: 16px; }
}

window#osd #container {
    margin: 16px;
    padding: {{ swayosd.padding_v }}px {{ swayosd.padding_h }}px;
    border-radius: {{ swayosd.radius }}px;
    background-color: alpha({{ colors.bg0 }}, {{ swayosd.bg_alpha }});
    border: 1px solid alpha({{ colors.bg3 }}, 0.55);
    box-shadow: 0 6px 20px alpha({{ colors.bg0 }}, 0.45),
                inset 0 1px 0 alpha({{ colors.fg_light }}, {{ glass.inner_highlight_alpha }});
    animation: osd-enter {{ motion.lifecycle_ms }}ms {{ motion.spring_curve }};
    font-family: "{{ fonts.mono_display }}", "{{ fonts.mono }}", monospace;
}

window#osd image,
window#osd label {
    color: {{ accents.swayosd.icon }};
    -gtk-icon-size: {{ swayosd.icon_size }}px;
}

window#osd progressbar {
    min-height: {{ swayosd.progress_height }}px;
    border-radius: {{ swayosd.progress_radius }}px;
    background-color: transparent;
}

window#osd progressbar trough {
    min-height: {{ swayosd.progress_height }}px;
    border-radius: {{ swayosd.progress_radius }}px;
    background-color: alpha({{ colors.bg3 }}, 0.55);
    border: none;
}

window#osd progressbar progress {
    min-height: {{ swayosd.progress_height }}px;
    border-radius: {{ swayosd.progress_radius }}px;
    background-color: {{ accents.swayosd.progress }};
    border: none;
    transition: min-width {{ motion.focus_ms }}ms {{ motion.focus_curve }};
}
