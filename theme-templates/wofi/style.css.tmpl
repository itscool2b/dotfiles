/* ━━━ Wofi — {{ meta.name }} ━━━ */

window {
    margin: 0;
    background-color: {{ colors.bg0 }};
    border: 2px solid {{ colors.bg3 }};
    border-radius: {{ geometry.wofi_radius }}px;
    font-family: "{{ fonts.mono }}", monospace;
    font-size: {{ fonts.size.wofi }}px;
}

#input {
    margin: 8px;
    padding: 10px 16px;
    border: none;
    border-bottom: 2px solid {{ accents.wofi.focus }};
    border-radius: {{ geometry.wofi_input_radius }}px;
    background-color: {{ colors.bg1 }};
    color: {{ colors.fg }};
    font-size: {{ fonts.size.wofi }}px;
    transition: border-bottom-color {{ motion.focus_ms }}ms {{ motion.focus_curve }};
}

#input:focus {
    border-bottom-color: {{ accents.wofi.focus }};
}

#inner-box {
    margin: 4px 8px;
    background-color: transparent;
}

#outer-box {
    margin: 0;
    padding: 0;
}

#scroll {
    margin: 0;
}

#text {
    margin: 0;
    padding: 6px 12px;
    color: {{ colors.fg }};
}

#entry {
    margin: 2px 0;
    padding: 8px 12px;
    border-radius: {{ geometry.wofi_entry_radius }}px;
    transition: background-color {{ motion.hover_ms }}ms {{ motion.hover_curve }},
                color {{ motion.hover_ms }}ms {{ motion.hover_curve }};
}

#entry:selected {
    background-color: {{ accents.wofi.selected_bg }};
    color: {{ accents.wofi.selected_fg }};
    border-left: 3px solid {{ accents.wofi.selection }};
    transition: background-color {{ motion.spring_ms }}ms {{ motion.spring_curve }},
                border-left {{ motion.spring_ms }}ms {{ motion.spring_curve }};
}

#entry:selected #text {
    color: {{ accents.wofi.selected_fg }};
    font-weight: bold;
}
