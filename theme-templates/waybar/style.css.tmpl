/* ━━━ Gruvbox Glass Waybar — Unified Slim Bar ━━━ */

@define-color bg0     {{ colors.bg0 }};
@define-color bg1     {{ colors.bg1 }};
@define-color bg2     {{ colors.bg2 }};
@define-color bg3     {{ colors.bg3 }};
@define-color fg      {{ colors.fg }};
@define-color fg_dim  {{ colors.fg_dim }};
@define-color red     {{ colors.bright_red }};
@define-color green   {{ colors.bright_green }};
@define-color yellow  {{ colors.bright_yellow }};
@define-color blue    {{ colors.bright_blue }};
@define-color purple  {{ colors.bright_purple }};
@define-color aqua    {{ colors.bright_cyan }};
@define-color orange  {{ colors.bright_orange }};

@define-color accent_workspace {{ accents.bar.workspace_active }};
@define-color accent_clock     {{ accents.bar.clock }};
@define-color accent_cpu       {{ accents.bar.cpu }};
@define-color accent_memory    {{ accents.bar.memory }};
@define-color accent_audio     {{ accents.bar.audio }};
@define-color accent_network   {{ accents.bar.network }};
@define-color accent_media     {{ accents.bar.media }};
@define-color accent_notif     {{ accents.bar.notification }};

* {
    font-family: "{{ fonts.mono }}", monospace;
    font-size: {{ fonts.size.bar }}px;
    min-height: 0;
    padding: 0;
    margin: 0;
}

/* ━━━ Unified bar background ━━━ */
window#waybar {
    background: alpha(@bg0, {{ opacity.bar_module_bg }});
    border: none;
    border-radius: {{ geometry.bar_radius }}px;
    color: @fg;
}

/* ━━━ Module base — no pills ━━━ */
#workspaces,
#window,
#clock,
#cpu,
#memory,
#pulseaudio,
#network,
#custom-media,
#custom-notification,
#tray {
    background: transparent;
    border: none;
    border-radius: 0;
    padding: 2px 12px;
    margin: 0 1px;
    transition: all {{ animations.bar_transition }} ease;
}

/* ━━━ Hover — subtle warm wash ━━━ */
#clock:hover,
#cpu:hover,
#memory:hover,
#pulseaudio:hover,
#network:hover,
#custom-media:hover,
#custom-notification:hover {
    background: alpha(@fg, {{ opacity.bar_module_hover }});
    border-radius: 6px;
}

/* ━━━ Group separators ━━━ */
#workspaces {
    border-right: 1px solid alpha(@bg3, 0.35);
    padding-right: 14px;
    margin-right: 6px;
}

#custom-media {
    border-right: 1px solid alpha(@bg3, 0.35);
    padding-right: 14px;
    margin-right: 6px;
}

#memory {
    border-right: 1px solid alpha(@bg3, 0.35);
    padding-right: 14px;
    margin-right: 6px;
}

/* ━━━ Workspaces — underline indicator ━━━ */
#workspaces {
    padding: 2px 8px;
}

#workspaces button {
    padding: 0 8px;
    margin: 0 2px;
    color: alpha(@fg_dim, 0.5);
    background: transparent;
    border: none;
    border-radius: 0;
    border-bottom: 2px solid transparent;
    transition: all {{ animations.bar_transition }} ease;
    min-width: 22px;
}

#workspaces button.active {
    color: @accent_workspace;
    background: transparent;
    border-bottom: 2px solid @accent_workspace;
    font-weight: bold;
}

#workspaces button:hover {
    color: @accent_workspace;
    background: transparent;
    border-bottom: 2px solid alpha(@accent_workspace, 0.4);
}

/* ━━━ Window title ━━━ */
#window {
    color: alpha(@fg_dim, 0.6);
    font-style: italic;
    font-size: {{ fonts.size.bar_title }}px;
    padding: 2px 10px;
}

/* ━━━ Clock ━━━ */
#clock {
    color: @accent_clock;
    font-weight: bold;
    font-size: {{ fonts.size.bar_clock }}px;
    padding: 2px 16px;
}

/* ━━━ Hardware ━━━ */
#cpu {
    color: @accent_cpu;
}

#memory {
    color: @accent_memory;
}

/* ━━━ Audio ━━━ */
#pulseaudio {
    color: @accent_audio;
}

#pulseaudio.muted {
    color: alpha(@fg_dim, 0.5);
}

/* ━━━ Network ━━━ */
#network {
    color: @accent_network;
}

#network.disconnected {
    color: @red;
}

/* ━━━ Media ━━━ */
#custom-media {
    color: @accent_media;
    font-style: italic;
}

/* ━━━ Notification bell ━━━ */
#custom-notification {
    color: @accent_notif;
}

/* ━━━ Tray ━━━ */
#tray {
    padding: 2px 8px;
}

#tray > .passive {
    -gtk-icon-effect: dim;
}

/* ━━━ Tooltip ━━━ */
tooltip {
    background: alpha(@bg1, {{ opacity.bar_tooltip }});
    border: 1px solid @bg3;
    border-radius: {{ geometry.bar_tooltip_radius }}px;
    color: @fg;
    padding: 8px;
}
