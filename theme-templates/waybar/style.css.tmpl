/* ━━━ {{ meta.name }} Waybar — v5 Ghost — dissolves into wallpaper ━━━ */
/* Generated from theme.toml — do not edit directly */

@define-color bg0       {{ colors.bg0 }};
@define-color bg1       {{ colors.bg1 }};
@define-color fg        {{ colors.fg }};
@define-color fg_mid    {{ colors.fg_mid }};
@define-color fg_dim    {{ colors.fg_dim }};
@define-color fg_light  {{ colors.fg_light }};
@define-color orange    {{ colors.bright_orange }};

* {
    font-family: "{{ fonts.mono_display }}", "{{ fonts.mono }}", monospace;
    font-size: {{ fonts.size.bar }}px;
    min-height: 0;
    padding: 0;
    margin: 0;
    text-shadow: 0 1px 2px rgba(0, 0, 0, 0.55);
}

/* ━━━ Bar: fully transparent — blends into wallpaper ━━━ */
window#waybar {
    background: alpha(@bg0, {{ opacity.bar_module_bg }});
    border: none;
    border-radius: {{ geometry.bar_radius }}px;
    color: @fg_dim;
}

.modules-left,
.modules-center,
.modules-right {
    background: transparent;
    padding: 0 10px;
    margin: 0;
    box-shadow: none;
    border-radius: 0;
}

/* ━━━ All modules: one muted tone, weight/alpha contrast only ━━━ */
#workspaces,
#clock,
#cpu,
#memory,
#pulseaudio,
#network,
#custom-media,
#custom-notification,
#tray {
    background: transparent;
    color: alpha(@fg_dim, 0.75);
    padding: 0 8px;
    margin: 0;
    border: none;
    border-radius: 0;
    font-weight: 400;
    letter-spacing: 0.02em;
    transition: color {{ motion.hover_ms }}ms {{ motion.hover_curve }};
}

/* ━━━ Clock: quietly central, mid-tone, no hero ━━━ */
#clock {
    color: @fg_mid;
    font-size: {{ fonts.size.bar_clock }}px;
    letter-spacing: 0.04em;
    padding: 0 16px;
}

/* ━━━ Media: plain text, same mute ━━━ */
#custom-media {
    color: alpha(@fg_dim, 0.75);
    font-style: normal;
}

/* ━━━ Notification: slight brighten when present ━━━ */
#custom-notification.notification,
#custom-notification.dnd-notification {
    color: @fg_mid;
}

/* ━━━ Workspaces: weight-only active, no color pop ━━━ */
#workspaces {
    padding: 0 4px;
}

#workspaces button {
    color: alpha(@fg_dim, 0.35);
    background: transparent;
    border: none;
    border-radius: 0;
    padding: 0 6px;
    margin: 0;
    min-width: 0;
    font-weight: 400;
    letter-spacing: 0.04em;
    transition: color {{ motion.spring_ms }}ms {{ motion.press_curve }};
}

#workspaces button.active {
    color: @fg_light;
    font-weight: 600;
}

#workspaces button.urgent {
    color: @orange;
}

#workspaces button:hover {
    color: alpha(@fg_light, 0.85);
}

/* ━━━ Hover: faint brighten, no bg fill ━━━ */
#clock:hover, #cpu:hover, #memory:hover, #pulseaudio:hover,
#network:hover, #custom-media:hover, #custom-notification:hover {
    color: @fg_mid;
}

/* Muted / disconnected — further fade */
#pulseaudio.muted,
#network.disconnected {
    color: alpha(@fg_dim, 0.3);
}

/* ━━━ Tray ━━━ */
#tray {
    padding: 0 6px;
}

#tray > .passive         { -gtk-icon-effect: dim; }
#tray > .needs-attention { -gtk-icon-effect: highlight; }

/* ━━━ Tooltips — soft surface, not chrome ━━━ */
tooltip {
    background: @bg1;
    border: 1px solid alpha(@fg_dim, 0.2);
    border-radius: {{ geometry.bar_tooltip_radius }}px;
    color: @fg;
    padding: 6px 10px;
}

tooltip label {
    color: @fg;
    padding: 2px 4px;
    text-shadow: none;
}
