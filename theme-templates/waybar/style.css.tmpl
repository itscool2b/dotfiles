/* ━━━ Gruvbox Dark Waybar — Pill Modules ━━━ */

@define-color bg0     {{ colors.bg0 }};
@define-color bg1     {{ colors.bg1 }};
@define-color bg2     {{ colors.bg2 }};
@define-color bg3     {{ colors.bg3 }};
@define-color fg      {{ colors.fg }};
@define-color fg_dim  {{ colors.fg_dim }};
@define-color red     {{ colors.bright_red }};
@define-color green   {{ colors.bright_green }};
@define-color yellow  {{ colors.bright_yellow }};
@define-color blue    {{ colors.bright_blue }};
@define-color purple  {{ colors.bright_purple }};
@define-color aqua    {{ colors.bright_cyan }};
@define-color orange  {{ colors.bright_orange }};

* {
    font-family: "{{ fonts.mono }}", monospace;
    font-size: {{ fonts.size.bar }}px;
    min-height: 0;
    padding: 0;
    margin: 0;
}

window#waybar {
    background: transparent;
    color: @fg;
}

/* ━━━ Pill module base ━━━ */
#workspaces,
#window,
#clock,
#cpu,
#memory,
#pulseaudio,
#network,
#custom-media,
#custom-notification,
#tray {
    background: alpha(@bg0, {{ opacity.bar_module_bg }});
    border: 1px solid alpha(@bg3, 0.4);
    border-radius: {{ geometry.bar_radius }}px;
    padding: 4px 14px;
    margin: 5px 3px;
    transition: all {{ animations.bar_transition }} ease;
}

#workspaces:hover,
#clock:hover,
#cpu:hover,
#memory:hover,
#pulseaudio:hover,
#network:hover,
#custom-media:hover,
#custom-notification:hover {
    background: alpha(@bg1, {{ opacity.bar_module_hover }});
    border-color: alpha(@bg3, 0.6);
}

/* ━━━ Workspaces ━━━ */
#workspaces {
    padding: 4px 6px;
}

#workspaces button {
    padding: 0 8px;
    margin: 0 2px;
    color: @fg_dim;
    background: transparent;
    border: none;
    border-radius: 10px;
    transition: all {{ animations.bar_transition }} ease;
    min-width: 24px;
}

#workspaces button.active {
    color: @bg0;
    background: @yellow;
    font-weight: bold;
    box-shadow: 0 0 8px alpha(@yellow, 0.4);
}

#workspaces button:hover {
    background: alpha(@yellow, 0.2);
    color: @yellow;
}

/* ━━━ Window title ━━━ */
#window {
    color: alpha(@fg_dim, 0.7);
    font-style: italic;
    font-size: {{ fonts.size.bar_title }}px;
}

/* ━━━ Clock ━━━ */
#clock {
    color: @green;
    font-weight: bold;
    font-size: {{ fonts.size.bar_clock }}px;
    padding: 4px 16px;
}

/* ━━━ Hardware ━━━ */
#cpu {
    color: @blue;
}

#memory {
    color: @purple;
}

/* ━━━ Audio ━━━ */
#pulseaudio {
    color: @aqua;
}

#pulseaudio.muted {
    color: @fg_dim;
    background: alpha(@bg0, 0.5);
}

/* ━━━ Network ━━━ */
#network {
    color: @orange;
}

#network.disconnected {
    color: @red;
}

/* ━━━ Media ━━━ */
#custom-media {
    color: @green;
    font-style: italic;
}

/* ━━━ Notification bell ━━━ */
#custom-notification {
    color: @yellow;
}

/* ━━━ Tray ━━━ */
#tray {
    padding: 4px 8px;
}

#tray > .passive {
    -gtk-icon-effect: dim;
}

/* ━━━ Tooltip ━━━ */
tooltip {
    background: alpha(@bg1, {{ opacity.bar_tooltip }});
    border: 1px solid @bg3;
    border-radius: {{ geometry.bar_tooltip_radius }}px;
    color: @fg;
    padding: 8px;
}
