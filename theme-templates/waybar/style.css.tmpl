/* ━━━ {{ meta.name }} Waybar — Flat Editorial Strip ━━━ */
/* Generated from theme.toml — do not edit directly */

@define-color bg0      {{ colors.bg0 }};
@define-color bg1      {{ colors.bg1 }};
@define-color bg2      {{ colors.bg2 }};
@define-color bg3      {{ colors.bg3 }};
@define-color fg       {{ colors.fg }};
@define-color fg_dim   {{ colors.fg_dim }};
@define-color fg_light {{ colors.fg_light }};
@define-color amber    {{ colors.amber }};

* {
    font-family: "{{ fonts.mono_display }}", "{{ fonts.mono }}", monospace;
    font-size: {{ fonts.size.bar }}px;
    min-height: 0;
    padding: 0;
    margin: 0;
}

/* ━━━ Bar: edge-aligned flat strip, thin hairline underneath ━━━ */
window#waybar {
    background: alpha(@bg0, {{ opacity.bar_module_bg }});
    border: none;
    border-bottom: 1px solid alpha(@fg_dim, 0.15);
    border-radius: {{ geometry.bar_radius }}px;
    color: @fg_dim;
}

/* ━━━ Pill groups: BLANK. Just padded columns. ━━━ */
.modules-left,
.modules-center,
.modules-right {
    background: transparent;
    padding: 0 12px;
    margin: 0;
    box-shadow: none;
    border-radius: 0;
}

/* ━━━ Modules — plain text on the bar, muted until hover ━━━ */
#workspaces,
#clock,
#cpu,
#memory,
#pulseaudio,
#network,
#custom-media,
#custom-notification,
#tray {
    background: transparent;
    color: @fg_dim;
    padding: 0 10px;
    margin: 0;
    border: none;
    border-radius: 0;
    letter-spacing: 0.04em;
    transition: color {{ motion.hover_ms }}ms {{ motion.hover_curve }};
}

/* ━━━ Clock — the steady amber anchor at center ━━━ */
#clock {
    color: @amber;
    font-weight: 600;
    font-size: {{ fonts.size.bar_clock }}px;
    letter-spacing: 0.08em;
    padding: 0 20px;
}

/* ━━━ Workspaces — numeric, hierarchy through opacity + weight ━━━ */
#workspaces {
    padding: 0 4px;
}

#workspaces button {
    color: alpha(@fg_dim, 0.45);
    background: transparent;
    border: none;
    border-radius: 0;
    padding: 0 6px;
    margin: 0;
    min-width: 0;
    font-weight: 500;
    letter-spacing: 0.08em;
    transition: color {{ motion.spring_ms }}ms {{ motion.press_curve }};
}

#workspaces button.active {
    color: @amber;
    font-weight: 700;
}

#workspaces button.urgent {
    color: @amber;
    font-style: italic;
}

#workspaces button:hover {
    color: @fg;
}

/* ━━━ Hover on modules — color shift only, no background ━━━ */
#cpu:hover,
#memory:hover,
#pulseaudio:hover,
#network:hover,
#custom-media:hover,
#custom-notification:hover,
#clock:hover {
    color: @fg;
}

/* ━━━ Media — italic quiet ━━━ */
#custom-media {
    font-style: italic;
}

/* ━━━ Notification — amber when any notification present ━━━ */
#custom-notification.notification,
#custom-notification.dnd-notification {
    color: @amber;
}

/* ━━━ Muted / disconnected states ━━━ */
#pulseaudio.muted,
#network.disconnected {
    color: alpha(@fg_dim, 0.4);
}

/* ━━━ Tray ━━━ */
#tray {
    padding: 0 8px;
}

#tray > .passive         { -gtk-icon-effect: dim; }
#tray > .needs-attention { -gtk-icon-effect: highlight; }

/* ━━━ Tooltips — flat hard-edge, tight ━━━ */
tooltip {
    background: @bg0;
    border: 1px solid alpha(@fg_dim, 0.2);
    border-radius: {{ geometry.bar_tooltip_radius }}px;
    color: @fg;
    padding: 6px 10px;
}

tooltip label {
    color: @fg;
    padding: 2px 4px;
}
