* {
    background-color: transparent;
    text-color:       {{ colors.fg }};
    margin:           0px;
    padding:          0px;
    spacing:          0px;
}

window {
    width:            {{ geometry.rofi_width }}px;
    background-color: {{ colors.bg0 }}{{ opacity.rofi_bg_alpha }};
    border:           1px;
    border-color:     {{ colors.fg_light }}{% if glass.inner_highlight_alpha %}{{ "%02x" | format((glass.inner_highlight_alpha * 255) | int) }}{% else %}00{% endif %};
    border-radius:    {{ geometry.rofi_radius }}px;
    location:         center;
    anchor:           center;
    transparency:     "real";
}

mainbox {
    padding:  {{ geometry.rofi_padding }}px;
    spacing:  10px;
    children: [inputbar, listview];
}

inputbar {
    children:         [prompt, entry];
    spacing:          10px;
    padding:          {{ geometry.rofi_inputbar_pad_v }}px {{ geometry.rofi_inputbar_pad_h }}px;
    background-color: white / {{ opacity.rofi_glass_input }}%;
    border:           2px;
    border-color:     {{ colors.bg3 }};
    border-radius:    {{ geometry.rofi_inputbar_radius }}px;
    transition-duration: {{ motion.focus_ms }};
}

prompt {
    text-color:     {{ accents.rofi.selection }};
    font:           "{{ fonts.mono_display }} {{ fonts.size.rofi_prompt }}";
    vertical-align: 0.5;
}

entry {
    placeholder:       "Search...";
    placeholder-color: {{ colors.bg4 }};
    text-color:        {{ colors.fg }};
    vertical-align:    0.5;
}

listview {
    lines:        {{ geometry.rofi_lines }};
    columns:      1;
    fixed-height: false;
    spacing:      {{ geometry.rofi_element_spacing }}px;
    scrollbar:    false;
}

element {
    padding:       {{ geometry.rofi_element_pad_v }}px {{ geometry.rofi_element_pad_h }}px;
    border-radius: {{ geometry.rofi_element_radius }}px;
    spacing:       14px;
    transition-duration: {{ motion.hover_ms }};
}

element normal.normal,
element alternate.normal {
    background-color: transparent;
    text-color:       {{ colors.fg_dim }};
}

element selected.normal {
    background-color: white / {{ opacity.rofi_glass_sel }}%;
    text-color:       {{ colors.fg }};
    transition-duration: {{ motion.spring_ms }};
}

element-icon {
    size:           {{ geometry.rofi_icon_size }}px;
    vertical-align: 0.5;
}

element-text {
    vertical-align: 0.5;
    text-color:     inherit;
    font:           "{{ fonts.sans }} {{ fonts.size.rofi }}";
}
