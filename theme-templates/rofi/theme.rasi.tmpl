/* ━━━ {{ meta.name }} Rofi — Flat editorial ━━━ */
/* Generated from theme.toml — do not edit directly */

* {
    background-color: transparent;
    text-color:       {{ colors.fg }};
    margin:           0px;
    padding:          0px;
    spacing:          0px;
}

window {
    width:            {{ geometry.rofi_width }}px;
    background-color: {{ colors.bg0 }}{{ opacity.rofi_bg_alpha }};
    border:           1px;
    border-color:     {{ colors.bg3 }};
    border-radius:    {{ geometry.rofi_radius }}px;
    location:         center;
    anchor:           center;
    transparency:     "real";
}

mainbox {
    padding:  {{ geometry.rofi_padding }}px;
    spacing:  12px;
    children: [inputbar, listview];
}

inputbar {
    children:         [prompt, entry];
    spacing:          12px;
    padding:          {{ geometry.rofi_inputbar_pad_v }}px {{ geometry.rofi_inputbar_pad_h }}px;
    background-color: {{ colors.bg1 }};
    border:           0 0 1px 0;
    border-color:     {{ colors.bg3 }};
    border-radius:    {{ geometry.rofi_inputbar_radius }}px;
    transition-duration: {{ motion.focus_ms }};
}

prompt {
    text-color:     {{ accents.rofi.selection }};
    font:           "{{ fonts.mono_display }} {{ fonts.size.rofi_prompt }}";
    vertical-align: 0.5;
    content:        "›";
}

entry {
    placeholder:       "search";
    placeholder-color: {{ colors.fg_dim }};
    text-color:        {{ colors.fg }};
    vertical-align:    0.5;
    font:              "{{ fonts.mono_display }} {{ fonts.size.rofi }}";
}

listview {
    lines:        {{ geometry.rofi_lines }};
    columns:      1;
    fixed-height: false;
    spacing:      {{ geometry.rofi_element_spacing }}px;
    scrollbar:    false;
}

element {
    padding:       {{ geometry.rofi_element_pad_v }}px {{ geometry.rofi_element_pad_h }}px;
    border:        0 0 0 2px;
    border-color:  transparent;
    border-radius: {{ geometry.rofi_element_radius }}px;
    spacing:       14px;
    transition-duration: {{ motion.hover_ms }};
}

element normal.normal,
element alternate.normal {
    background-color: transparent;
    text-color:       {{ colors.fg_dim }};
}

element selected.normal {
    background-color: {{ colors.bg2 }};
    text-color:       {{ colors.fg }};
    border-color:     {{ accents.rofi.selection }};
    transition-duration: {{ motion.spring_ms }};
}

element-icon {
    size:           {{ geometry.rofi_icon_size }}px;
    vertical-align: 0.5;
    enabled:        true;
}

element-text {
    vertical-align: 0.5;
    text-color:     inherit;
    font:           "{{ fonts.mono_display }} {{ fonts.size.rofi }}";
}
