* {
    bg0:     {{ colors.bg0 }}{{ opacity.rofi_bg_alpha }};
    bg1:     {{ colors.bg1 }};
    bg2:     {{ colors.bg2 }};
    bg3:     {{ colors.bg3 }};
    fg0:     {{ colors.fg }};
    fg1:     {{ colors.fg_dim }};
    red:     {{ colors.bright_red }};
    green:   {{ colors.bright_green }};
    yellow:  {{ colors.bright_yellow }};
    blue:    {{ colors.bright_blue }};
    orange:  {{ colors.bright_orange }};

    background-color: transparent;
    text-color: @fg0;
}

window {
    width: {{ geometry.rofi_width }}px;
    padding: 20px;
    background-color: @bg0;
    border: 2px solid;
    border-color: @bg3;
    border-radius: {{ geometry.rofi_radius }}px;
    location: center;
    anchor: center;
}

mainbox {
    spacing: 16px;
    children: [inputbar, listview];
}

inputbar {
    children: [prompt, entry];
    spacing: 8px;
    padding: 12px 16px;
    background-color: @bg1;
    border-radius: {{ geometry.rofi_inputbar_radius }}px;
}

prompt {
    text-color: @yellow;
    font: "{{ fonts.mono }} {{ fonts.size.rofi_prompt }}";
}

entry {
    placeholder: "Search applications...";
    placeholder-color: @fg1;
    text-color: @fg0;
}

listview {
    lines: {{ geometry.rofi_lines }};
    columns: 1;
    fixed-height: true;
    spacing: 4px;
    scrollbar: false;
}

element {
    padding: 10px 14px;
    border-radius: {{ geometry.rofi_element_radius }}px;
    spacing: 12px;
}

element normal.normal {
    background-color: transparent;
}

element selected.normal {
    background-color: @bg2;
    text-color: @yellow;
    border: 0 0 0 3px solid;
    border-color: @yellow;
}

element-icon {
    size: {{ geometry.rofi_icon_size }}px;
    vertical-align: 0.5;
}

element-text {
    vertical-align: 0.5;
    text-color: inherit;
}
