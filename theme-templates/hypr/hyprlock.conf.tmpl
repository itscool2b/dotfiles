general {
    grace = 5
    hide_cursor = true
}

background {
    monitor =
    path = {{ wallpaper.path }}
    blur_passes = {{ blur.lock_passes }}
    blur_size = {{ blur.lock_size }}
    noise = {{ blur.lock_noise }}
    contrast = {{ blur.lock_contrast }}
    brightness = {{ blur.lock_brightness }}
    vibrancy = 0.15
}

# Time — the editorial statement. Amber, centered, confident.
label {
    monitor =
    text = $TIME
    color = {{ colors.bright_yellow | rgba("ff") }}
    font_size = {{ fonts.size.hyprlock_time }}
    font_family = {{ fonts.mono_display }}
    position = 0, 160
    halign = center
    valign = center
    shadow_passes = 1
    shadow_size = 3
    shadow_color = {{ colors.bg0 | rgba("77") }}
}

# Date — muted, tracked
label {
    monitor =
    text = cmd[update:3600000] date +"%A, %B %d"
    color = {{ colors.fg_dim | rgba("ff") }}
    font_size = {{ fonts.size.hyprlock_date }}
    font_family = {{ fonts.mono_display }}
    position = 0, 70
    halign = center
    valign = center
}

input-field {
    monitor =
    size = {{ geometry.hyprlock_input_width }}, {{ geometry.hyprlock_input_height }}
    outline_thickness = {{ geometry.hyprlock_input_border }}
    dots_size = 0.22
    dots_spacing = 0.35
    dots_center = true
    outer_color = {{ accents.hyprlock.outer | rgba("ff") }}
    inner_color = {{ colors.bg1 | rgba("cc") }}
    font_color = {{ colors.fg | rgba("ff") }}
    fade_on_empty = true
    placeholder_text = <span foreground="##{{ colors.fg_dim | bare }}">password</span>
    hide_input = false
    rounding = {{ geometry.hyprlock_input_radius }}
    check_color = {{ accents.hyprlock.check | rgba("ff") }}
    fail_color = {{ accents.hyprlock.fail | rgba("ff") }}
    fail_text = <span foreground="##{{ accents.hyprlock.fail | bare }}">$FAIL</span>
    position = 0, -40
    halign = center
    valign = center
    shadow_passes = 0
}
