{
    "$schema": "https://github.com/fastfetch-cli/fastfetch/raw/dev/doc/json_schema.json",

    "logo": {
        "source": "CachyOS_small",
        "color": {
            "1": "{{ colors.bright_blue | ansi }}",
            "2": "{{ colors.bright_cyan | ansi }}"
        },
        "padding": {
            "top": 5,
            "left": 2,
            "right": 4
        }
    },

    "display": {
        "separator": "",
        "key": {
            "width": 1
        },
        "color": {
            "output": "{{ colors.fg | ansi }}"
        }
    },

    "modules": [
        {
            "type": "title",
            "format": "\u001b[1m\u001b[{{ colors.bright_yellow | ansi }}m{user-name}\u001b[0m\u001b[{{ colors.gray | ansi }}m@\u001b[1m\u001b[{{ colors.bright_green | ansi }}m{host-name}\u001b[0m",
            "key": " ",
            "keyColor": "{{ colors.bg3 | ansi }}"
        },
        {
            "type": "command",
            "key": " ",
            "keyColor": "{{ colors.bg3 | ansi }}",
            "text": "printf '\\033[{{ colors.bg3 | ansi }}m─────────────────────────────'"
        },
        "break",
        {
            "type": "os",
            "key": " ",
            "keyColor": "{{ colors.bright_blue | ansi }}",
            "format": "\u001b[{{ colors.bright_blue | ansi }}m󰣇 \u001b[{{ colors.gray | ansi }}mos    \u001b[{{ colors.bright_blue | ansi }}m{pretty-name}"
        },
        {
            "type": "kernel",
            "key": " ",
            "keyColor": "{{ colors.bright_cyan | ansi }}",
            "format": "\u001b[{{ colors.bright_cyan | ansi }}m󰌽 \u001b[{{ colors.gray | ansi }}mkern  \u001b[{{ colors.bright_cyan | ansi }}m{release}"
        },
        {
            "type": "packages",
            "key": " ",
            "keyColor": "{{ colors.bright_orange | ansi }}",
            "format": "\u001b[{{ colors.bright_orange | ansi }}m󰏗 \u001b[{{ colors.gray | ansi }}mpkgs  \u001b[{{ colors.bright_orange | ansi }}m{all}"
        },
        {
            "type": "shell",
            "key": " ",
            "keyColor": "{{ colors.bright_green | ansi }}",
            "format": "\u001b[{{ colors.bright_green | ansi }}m󰆍 \u001b[{{ colors.gray | ansi }}msh    \u001b[{{ colors.bright_green | ansi }}m{pretty-name} {version}"
        },
        {
            "type": "uptime",
            "key": " ",
            "keyColor": "{{ colors.bright_yellow | ansi }}",
            "format": "\u001b[{{ colors.bright_yellow | ansi }}m󰥔 \u001b[{{ colors.gray | ansi }}mup    \u001b[{{ colors.bright_yellow | ansi }}m{formatted}"
        },
        "break",
        {
            "type": "wm",
            "key": " ",
            "keyColor": "{{ colors.bright_purple | ansi }}",
            "format": "\u001b[{{ colors.bright_purple | ansi }}m󰍹 \u001b[{{ colors.gray | ansi }}mwm    \u001b[{{ colors.bright_purple | ansi }}m{pretty-name}"
        },
        {
            "type": "terminal",
            "key": " ",
            "keyColor": "{{ colors.bright_blue | ansi }}",
            "format": "\u001b[{{ colors.bright_blue | ansi }}m󰞷 \u001b[{{ colors.gray | ansi }}mterm  \u001b[{{ colors.bright_blue | ansi }}m{pretty-name}"
        },
        {
            "type": "cpu",
            "key": " ",
            "keyColor": "{{ colors.bright_green | ansi }}",
            "format": "\u001b[{{ colors.bright_green | ansi }}m󰘚 \u001b[{{ colors.gray | ansi }}mcpu   \u001b[{{ colors.bright_green | ansi }}m{name}"
        },
        {
            "type": "gpu",
            "key": " ",
            "keyColor": "{{ colors.bright_red | ansi }}",
            "format": "\u001b[{{ colors.bright_red | ansi }}m󰢮 \u001b[{{ colors.gray | ansi }}mgpu   \u001b[{{ colors.bright_red | ansi }}m{name}"
        },
        {
            "type": "memory",
            "key": " ",
            "keyColor": "{{ colors.bright_yellow | ansi }}",
            "format": "\u001b[{{ colors.bright_yellow | ansi }}m󰍛 \u001b[{{ colors.gray | ansi }}mmem   \u001b[{{ colors.bright_yellow | ansi }}m{used} \u001b[{{ colors.gray | ansi }}m/ \u001b[{{ colors.fg_dim | ansi }}m{total}"
        },
        {
            "type": "disk",
            "key": " ",
            "keyColor": "{{ colors.bright_orange | ansi }}",
            "format": "\u001b[{{ colors.bright_orange | ansi }}m󰋊 \u001b[{{ colors.gray | ansi }}mdisk  \u001b[{{ colors.bright_orange | ansi }}m{size-used} \u001b[{{ colors.gray | ansi }}m/ \u001b[{{ colors.fg_dim | ansi }}m{size-total}",
            "folders": "/"
        },
        "break",
        {
            "type": "command",
            "key": " ",
            "keyColor": "{{ colors.bg3 | ansi }}",
            "text": "printf '\\033[{{ colors.bright_red | ansi }}m● \\033[{{ colors.bright_orange | ansi }}m● \\033[{{ colors.bright_yellow | ansi }}m● \\033[{{ colors.bright_green | ansi }}m● \\033[{{ colors.bright_cyan | ansi }}m● \\033[{{ colors.bright_blue | ansi }}m● \\033[{{ colors.bright_purple | ansi }}m● \\033[{{ colors.fg | ansi }}m●'"
        },
        {
            "type": "command",
            "key": " ",
            "keyColor": "{{ colors.bg3 | ansi }}",
            "text": "printf '\\033[{{ colors.red | ansi }}m○ \\033[{{ colors.orange | ansi }}m○ \\033[{{ colors.yellow | ansi }}m○ \\033[{{ colors.green | ansi }}m○ \\033[{{ colors.cyan | ansi }}m○ \\033[{{ colors.blue | ansi }}m○ \\033[{{ colors.purple | ansi }}m○ \\033[{{ colors.fg_dim | ansi }}m○'"
        }
    ]
}
