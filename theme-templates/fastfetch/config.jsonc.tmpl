{
    "$schema": "https://github.com/fastfetch-cli/fastfetch/raw/dev/doc/json_schema.json",

    "logo": {
        "type": "{{ fastfetch.logo_type }}",
        "source": "{{ fastfetch.logo_source }}",
        "color": {
            "1": "{{ colors[fastfetch.logo_color_solid] | ansi }}",
            "2": "{{ colors[fastfetch.logo_color_solid] | ansi }}",
            "3": "{{ colors[fastfetch.logo_color_solid] | ansi }}",
            "4": "{{ colors[fastfetch.logo_color_solid] | ansi }}",
            "5": "{{ colors[fastfetch.logo_color_solid] | ansi }}",
            "6": "{{ colors[fastfetch.logo_color_solid] | ansi }}"
        },
        "padding": {
            "top": {{ fastfetch.logo_padding_top }},
            "left": {{ fastfetch.logo_padding_left }},
            "right": {{ fastfetch.logo_padding_right }}
        }
    },

    "display": {
        "separator": "",
        "key": {
            "width": 1
        },
        "color": {
            "output": "{{ colors.fg | ansi }}"
        }
    },

    "modules": [
        {
            "type": "title",
            "format": "\u001b[1m\u001b[{{ colors.bright_yellow | ansi }}m{user-name}\u001b[0m\u001b[{{ colors.fg_dim | ansi }}m@\u001b[1m\u001b[{{ colors.bright_green | ansi }}m{host-name}\u001b[0m",
            "key": " ",
            "keyColor": "{{ colors.bg3 | ansi }}"
        },
        {
            "type": "command",
            "key": " ",
            "keyColor": "{{ colors.bg3 | ansi }}",
            "text": "printf '\\033[{{ colors.bg3 | ansi }}m‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ'"
        },
        "break",
        {
            "type": "os",
            "key": " ",
            "keyColor": "{{ accents.fetch.os | ansi }}",
            "format": "\u001b[{{ accents.fetch.os | ansi }}mÛ∞£á \u001b[{{ colors.gray | ansi }}mos    \u001b[{{ accents.fetch.os | ansi }}m{pretty-name}"
        },
        {
            "type": "kernel",
            "key": " ",
            "keyColor": "{{ accents.fetch.kernel | ansi }}",
            "format": "\u001b[{{ accents.fetch.kernel | ansi }}mÛ∞åΩ \u001b[{{ colors.gray | ansi }}mkern  \u001b[{{ accents.fetch.kernel | ansi }}m{release}"
        },
        {
            "type": "packages",
            "key": " ",
            "keyColor": "{{ accents.fetch.packages | ansi }}",
            "format": "\u001b[{{ accents.fetch.packages | ansi }}mÛ∞èó \u001b[{{ colors.gray | ansi }}mpkgs  \u001b[{{ accents.fetch.packages | ansi }}m{all}"
        },
        {
            "type": "shell",
            "key": " ",
            "keyColor": "{{ accents.fetch.shell | ansi }}",
            "format": "\u001b[{{ accents.fetch.shell | ansi }}mÛ∞Üç \u001b[{{ colors.gray | ansi }}msh    \u001b[{{ accents.fetch.shell | ansi }}m{pretty-name} {version}"
        },
        {
            "type": "uptime",
            "key": " ",
            "keyColor": "{{ accents.fetch.uptime | ansi }}",
            "format": "\u001b[{{ accents.fetch.uptime | ansi }}mÛ∞•î \u001b[{{ colors.gray | ansi }}mup    \u001b[{{ accents.fetch.uptime | ansi }}m{formatted}"
        },
        "break",
        {
            "type": "wm",
            "key": " ",
            "keyColor": "{{ accents.fetch.wm | ansi }}",
            "format": "\u001b[{{ accents.fetch.wm | ansi }}mÛ∞çπ \u001b[{{ colors.gray | ansi }}mwm    \u001b[{{ accents.fetch.wm | ansi }}m{pretty-name}"
        },
        {
            "type": "terminal",
            "key": " ",
            "keyColor": "{{ accents.fetch.terminal | ansi }}",
            "format": "\u001b[{{ accents.fetch.terminal | ansi }}mÛ∞û∑ \u001b[{{ colors.gray | ansi }}mterm  \u001b[{{ accents.fetch.terminal | ansi }}m{pretty-name}"
        },
        {
            "type": "cpu",
            "key": " ",
            "keyColor": "{{ accents.fetch.cpu | ansi }}",
            "format": "\u001b[{{ accents.fetch.cpu | ansi }}mÛ∞òö \u001b[{{ colors.gray | ansi }}mcpu   \u001b[{{ accents.fetch.cpu | ansi }}m{name}"
        },
        {
            "type": "gpu",
            "key": " ",
            "keyColor": "{{ accents.fetch.gpu | ansi }}",
            "format": "\u001b[{{ accents.fetch.gpu | ansi }}mÛ∞¢Æ \u001b[{{ colors.gray | ansi }}mgpu   \u001b[{{ accents.fetch.gpu | ansi }}m{name}"
        },
        {
            "type": "memory",
            "key": " ",
            "keyColor": "{{ accents.fetch.memory | ansi }}",
            "format": "\u001b[{{ accents.fetch.memory | ansi }}mÛ∞çõ \u001b[{{ colors.gray | ansi }}mmem   \u001b[{{ accents.fetch.memory | ansi }}m{used} \u001b[{{ colors.gray | ansi }}m/ \u001b[{{ colors.fg_dim | ansi }}m{total}"
        },
        {
            "type": "disk",
            "key": " ",
            "keyColor": "{{ accents.fetch.disk | ansi }}",
            "format": "\u001b[{{ accents.fetch.disk | ansi }}mÛ∞ãä \u001b[{{ colors.gray | ansi }}mdisk  \u001b[{{ accents.fetch.disk | ansi }}m{size-used} \u001b[{{ colors.gray | ansi }}m/ \u001b[{{ colors.fg_dim | ansi }}m{size-total}",
            "folders": "/"
        },
        "break",
        {
            "type": "command",
            "key": " ",
            "keyColor": "{{ colors.bg3 | ansi }}",
            "text": "printf '\\033[{{ colors.bright_red | ansi }}m‚óè \\033[{{ colors.bright_orange | ansi }}m‚óè \\033[{{ colors.bright_yellow | ansi }}m‚óè \\033[{{ colors.bright_green | ansi }}m‚óè \\033[{{ colors.bright_cyan | ansi }}m‚óè \\033[{{ colors.bright_blue | ansi }}m‚óè \\033[{{ colors.bright_purple | ansi }}m‚óè \\033[{{ colors.fg | ansi }}m‚óè'"
        },
        {
            "type": "command",
            "key": " ",
            "keyColor": "{{ colors.bg3 | ansi }}",
            "text": "printf '\\033[{{ colors.red | ansi }}m‚óã \\033[{{ colors.orange | ansi }}m‚óã \\033[{{ colors.yellow | ansi }}m‚óã \\033[{{ colors.green | ansi }}m‚óã \\033[{{ colors.cyan | ansi }}m‚óã \\033[{{ colors.blue | ansi }}m‚óã \\033[{{ colors.purple | ansi }}m‚óã \\033[{{ colors.fg_dim | ansi }}m‚óã'"
        }
    ]
}
