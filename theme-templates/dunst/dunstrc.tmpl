[global]
    width = 350
    height = 100
    offset = 12x12
    origin = top-right
    transparency = 10
    frame_color = "{{ colors.bg3 }}"
    frame_width = 2
    corner_radius = {{ geometry.dunst_radius }}
    font = {{ fonts.mono }} {{ fonts.size.dunst }}
    padding = 12
    horizontal_padding = 16
    icon_position = left
    max_icon_size = 48
    separator_color = frame
    gap_size = 6

[urgency_low]
    background = "{{ colors.bg0 }}"
    foreground = "{{ colors.fg_dim }}"
    timeout = 4

[urgency_normal]
    background = "{{ colors.bg1 }}"
    foreground = "{{ colors.fg }}"
    highlight = "{{ colors.yellow }}"
    timeout = 6

[urgency_critical]
    background = "{{ colors.red }}"
    foreground = "{{ colors.fg }}"
    frame_color = "{{ colors.bright_red }}"
    timeout = 0
