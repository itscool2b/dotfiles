[global]
    width = 350
    height = 100
    offset = 12x12
    origin = top-right
    transparency = 0
    frame_color = "{{ colors.bg3 }}"
    frame_width = {{ geometry.dunst_frame_width }}
    corner_radius = {{ geometry.dunst_radius }}
    font = {{ fonts.mono_display }} {{ fonts.size.dunst }}
    padding = {{ geometry.dunst_padding }}
    horizontal_padding = {{ geometry.dunst_h_padding }}
    icon_position = off
    max_icon_size = 0
    separator_color = auto
    separator_height = 1
    gap_size = {{ geometry.dunst_gap }}

[urgency_low]
    background = "{{ colors.bg0 }}"
    foreground = "{{ colors.fg_dim }}"
    timeout = 4

[urgency_normal]
    background = "{{ colors.bg1 }}"
    foreground = "{{ colors.fg }}"
    highlight = "{{ colors.amber }}"
    timeout = 6

[urgency_critical]
    background = "{{ colors.bg1 }}"
    foreground = "{{ colors.fg }}"
    highlight = "{{ colors.bright_red }}"
    timeout = 0
